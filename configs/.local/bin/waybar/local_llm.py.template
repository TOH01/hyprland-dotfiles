#!/usr/bin/env python3

from platformdirs import user_cache_dir
import json
import argparse
from pathlib import Path
import subprocess
import sys

CACHE_DIR = Path(user_cache_dir())

MODELS = json.loads('{{$LLM_MODELS}}')
ACTIVE_MODEL_FILE = CACHE_DIR / "waybar_llm_mode"
STATE_FILE = CACHE_DIR / "waybar_mode"
SERVICE_NAME = "local_llm.service"

HOME_DIR = Path.home()
SYSTEMD_SERVICE_FILE = HOME_DIR / ".config" / "systemd" / "user" / SERVICE_NAME
SYSTEMD_SERVICE_ENV_FILE = CACHE_DIR / "llm_env"

def write_state(state: str) -> None:
    with open(ACTIVE_MODEL_FILE, "w") as f:
        f.write(state)

def read_model_name() -> str:
    try:
        with open(ACTIVE_MODEL_FILE, "r") as f:
            return f.read()
    except Exception:
        model = next(iter(MODELS))
        write_state(model)
        return model

def is_llm_mode() -> bool:
    try:
        with open(STATE_FILE) as f:
            return f.read().strip() == "WORK"
    except Exception:
        return False

def get_next_model(current: str) -> str:
    keys = list(MODELS.keys())
    idx = keys.index(current)
    return keys[(idx + 1) % len(keys)]

def apply_mode(model: str):
    command = MODELS[model]
    SYSTEMD_SERVICE_ENV_FILE.write_text(f'LLM_MODEL_CMD="{command}"\n')
    subprocess.run(["systemctl", "--user", "restart", SERVICE_NAME])

if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--apply", action="store_true")
    args = parser.parse_args()

    if not is_llm_mode():
        print('{"text": ""}')
        sys.exit(1)
    
    if not MODELS:
        print(f"Missing model config: {MODELS}")
        sys.exit(1)

    model_name = read_model_name()

    if model_name not in MODELS.keys():
        Path(ACTIVE_MODEL_FILE).unlink(missing_ok=True)
        model_name = read_model_name()


    if args.apply:
        print('{"text": "' + model_name + '"}')
    else:
        next_model = get_next_model(model_name)
        apply_mode(next_model)
        write_state(next_model)
        subprocess.run(["pkill", "-RTMIN+9", "waybar"],
                       stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        print('{"text": "' + next_model + '"}')
