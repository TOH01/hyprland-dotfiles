#!/usr/bin/env bash

set -euo pipefail

OPENWEBUI_BIN="${OPENWEBUI_BIN:-/home/tobi/.conda/envs/open-webui/bin/open-webui}"
OPENWEBUI_HOST="${OPENWEBUI_HOST:-127.0.0.1}"
OPENWEBUI_PORT="${OPENWEBUI_PORT:-18080}"
OPENWEBUI_URL="${OPENWEBUI_URL:-http://${OPENWEBUI_HOST}:${OPENWEBUI_PORT}}"
BROWSER_CMD="${OPENWEBUI_BROWSER:-${BROWSER:-firefox}}"
DATA_DIR="${OPENWEBUI_DATA_DIR:-${XDG_DATA_HOME:-${HOME}/.local/share}/openwebui-noauth}"
STATE_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/openwebui-noauth"
SERVER_LOG="${STATE_DIR}/server.log"
LAUNCHER_LOG="${STATE_DIR}/launcher.log"
PID_FILE="${STATE_DIR}/server.pid"
SECRET_KEY_FILE="${STATE_DIR}/webui_secret_key"

mkdir -p "${STATE_DIR}" "${DATA_DIR}"

log() {
    printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "${LAUNCHER_LOG}"
}

notify() {
    local message="$1"

    if command -v notify-send > /dev/null 2>&1; then
        notify-send "Open WebUI" "${message}"
    fi
}

is_webui_ready() {
    curl --silent --fail --max-time 2 "${OPENWEBUI_URL}" > /dev/null 2>&1
}

ensure_secret_key() {
    if [[ ! -s "${SECRET_KEY_FILE}" ]]; then
        head -c 24 /dev/urandom | base64 > "${SECRET_KEY_FILE}"
        printf '\n' >> "${SECRET_KEY_FILE}"
        chmod 600 "${SECRET_KEY_FILE}"
    fi
}

is_launcher_process_running() {
    if [[ ! -f "${PID_FILE}" ]]; then
        return 1
    fi

    local pid
    pid="$(<"${PID_FILE}")"

    [[ -n "${pid}" ]] && kill -0 "${pid}" 2>/dev/null
}

wait_for_webui() {
    local attempts="${1:-30}"

    while (( attempts > 0 )); do
        if is_webui_ready; then
            return 0
        fi

        sleep 1
        ((attempts--))
    done

    return 1
}

open_browser() {
    if command -v "${BROWSER_CMD}" > /dev/null 2>&1; then
        if [[ "$(basename -- "${BROWSER_CMD}")" == firefox* ]]; then
            "${BROWSER_CMD}" --new-tab "${OPENWEBUI_URL}" > /dev/null 2>&1 &
        else
            "${BROWSER_CMD}" "${OPENWEBUI_URL}" > /dev/null 2>&1 &
        fi
        return 0
    fi

    if command -v xdg-open > /dev/null 2>&1; then
        xdg-open "${OPENWEBUI_URL}" > /dev/null 2>&1 &
        return 0
    fi

    notify "Open WebUI is running, but no browser launcher was found."
    return 1
}

if [[ ! -x "${OPENWEBUI_BIN}" ]]; then
    log "Open WebUI binary not found at ${OPENWEBUI_BIN}"
    notify "Couldn't find ${OPENWEBUI_BIN}."
    exit 1
fi

ensure_secret_key

if is_webui_ready; then
    log "Open WebUI already running; opening browser."
    open_browser
    exit 0
fi

if is_launcher_process_running; then
    log "Open WebUI process already starting; waiting for it to become ready."
else
    if [[ -f "${PID_FILE}" ]]; then
        rm -f "${PID_FILE}"
    fi

    log "Starting no-login Open WebUI on ${OPENWEBUI_URL}."
    env \
        DATA_DIR="${DATA_DIR}" \
        WEBUI_AUTH="False" \
        WEBUI_SECRET_KEY="$(<"${SECRET_KEY_FILE}")" \
        PATH="/home/tobi/.conda/envs/open-webui/bin:/usr/bin:/bin" \
        nohup "${OPENWEBUI_BIN}" serve --host "${OPENWEBUI_HOST}" --port "${OPENWEBUI_PORT}" >> "${SERVER_LOG}" 2>&1 &

    printf '%s\n' "$!" > "${PID_FILE}"
fi

if wait_for_webui 90; then
    log "No-login Open WebUI is ready; opening browser."
    open_browser
    exit 0
fi

log "Open WebUI did not become ready in time. Check ${SERVER_LOG}."
notify "Open WebUI did not start in time. See ${SERVER_LOG}."
exit 1
