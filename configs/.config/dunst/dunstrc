[global]
    follow = keyboard
    
    origin = bottom-right
    
    offset = (20, 20)
    
    width = (0, 400)
    height = (0, 150)
    
    corner_radius = 12
    
    font = JetBrains Mono 11
    
    padding = 18
    horizontal_padding = 18
    text_icon_padding = 10
    
    progress_bar = true
    progress_bar_height = 4
    progress_bar_frame_width = 0
    progress_bar_corner_radius = 2

    background = "{{THEME_BG_FLOATING_HEX}}" 
    foreground = "{{THEME_TEXT_HEX}}"
    frame_color = "{{THEME_BORDER_HEX}}"
    frame_width = 1

    timeout = 5

[urgency_low]
    background = "{{THEME_BG_FLOATING_HEX}}"
    foreground = "{{THEME_TEXT_HEX}}"

[urgency_normal]
    background = "{{THEME_BG_FLOATING_HEX}}"
    foreground = "{{THEME_TEXT_HEX}}"

[urgency_critical]
    background = "{{THEME_DUNST_CRITICAL_BG_HEX}}"
    foreground = "{{THEME_DUNST_CRITICAL_FG_HEX}}"
    frame_color = "{{THEME_DUNST_CRITICAL_FRAME_HEX}}"
